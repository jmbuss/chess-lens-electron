{
  "name": "chess-lens",
  "productName": "Chess Lens",
  "version": "0.1.3",
  "description": "A desktop chess analysis tool",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx,.vue .",
    "lint:fix": "eslint --ext .ts,.tsx,.vue . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:engine": "tsx src/services/engine/test-runner.ts"
  },
